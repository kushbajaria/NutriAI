{
  "expo": {
    "name": "NutriAI",
    "slug": "nutriai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0f0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutriai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0f0a"
      },
      "package": "com.nutriai.app"
    },
    "scheme": "nutriai",
    "plugins": [
      "expo-router"
    ]
  }
}
